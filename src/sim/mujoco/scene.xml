<mujoco>
  <option timestep="0.001" integrator="implicitfast" noslip_iterations="10" noslip_tolerance="1e-6" />
  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512" />
    <texture name="body" type="cube" builtin="flat" mark="cross" width="32" height="32"
      rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1" />
    <material name="body" texture="body" texuniform="true" rgba="0.8 0.6 .4 1" />
    <texture name="grid" type="2d" builtin="checker" width="128" height="128"
      rgb1=".1 .2 .3" rgb2=".2 .3 .4" />
    <material name="grid" texture="grid" texrepeat="10 10" texuniform="true" reflectance=".2" />
    <model name="panda_arm" file="franka_emika_panda/panda.xml" />
  </asset>
  <worldbody>
    <light name="main" pos="0 0 2.5" type="point" />

    <camera name="main" pos="0 0 2.5" euler="0 0 -90" />
    <camera name="side" pos="0.0 -2.5 0.1" euler="90 0 0" />
    <camera name="front" pos="2.5 0.0 0.1" euler="90 90 0" />

    <geom type="plane" size="2.0 2.0 0.1" material="grid"
      condim="4"
      friction="1.0 0.5 0.001"
      solimp="0.99 0.999 0.001"
      solref="0.002 1" />

    <body name="arm" pos="0 0 0">
      <attach model="panda_arm" body="link0" prefix="" />
    </body>

    <body name="ball" pos="0.25 -0.40 0.025">
      <freejoint />
      <inertial pos="0.0 0.0 0.0" mass="0.05" diaginertia="2e-5 2e-5 2e-5" />
      <geom type="sphere" pos="0.0 0.0 0.0" size="0.025" rgba="1 0 0 1" condim="4"
        friction="5.0 2.0 0.001"
        solimp="0.99 0.999 0.001" solref="0.002 1" />
    </body>
    <body name="box" pos="0.375 -0.40 0.025">
      <freejoint />
      <inertial pos="0.0 0.0 0.0" mass="0.05" diaginertia="2e-5 2e-5 2e-5" />
      <geom type="box" pos="0.0 0.0 0.0" size="0.025 0.025 0.025" rgba="0 1 0 1" condim="4"
        friction="5.0 2.0 0.001"
        solimp="0.99 0.999 0.001" solref="0.002 1" />
    </body>
    <body name="cylinder" pos="0.5 -0.40 0.025">
      <freejoint />
      <inertial pos="0.0 0.0 0.0" mass="0.05" diaginertia="2e-5 2e-5 2e-5" />
      <geom type="cylinder" pos="0.0 0.0 0.0" size="0.025 0.025" rgba="0 0 1 1" condim="4"
        friction="5.0 2.0 0.001"
        solimp="0.99 0.999 0.001" solref="0.002 1" />
    </body>

    <body name="platform" pos="0.375 0.40 0.005">
      <geom type="box" pos="0.0 0.0 0.0" size="0.25 0.25 0.005" rgba="0 0 0 1" condim="4"
        friction="5.0 2.0 0.001"
        solimp="0.99 0.999 0.001" solref="0.002 1" />
    </body>
  </worldbody>
  <sensor>
    <jointpos name="joint1" joint="joint1" />
    <jointpos name="joint2" joint="joint2" />
    <jointpos name="joint3" joint="joint3" />
    <jointpos name="joint4" joint="joint4" />
    <jointpos name="joint5" joint="joint5" />
    <jointpos name="joint6" joint="joint6" />
    <jointpos name="joint7" joint="joint7" />
    <jointpos name="finger_joint1" joint="finger_joint1" />
    <jointpos name="finger_joint2" joint="finger_joint2" />
  </sensor>
</mujoco>
